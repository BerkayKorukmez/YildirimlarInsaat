{
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)\\.(jpg|jpeg|png|gif|webp|svg|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(css|js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "redirects": [
    { "source": "/hizmetler", "destination": "/#hizmetler", "permanent": false },
    { "source": "/hizmetler/endustriyel-zemin.html", "destination": "/hizmetler/endustriyel-beton-zemin.html", "permanent": true },
    { "source": "/hizmetler/beton-parlatma.html", "destination": "/hizmetler/parlak-perdahli-zemin.html", "permanent": true },
    { "source": "/hizmetler/silim-kesim.html", "destination": "/hizmetler/derz-kesim-dolgu.html", "permanent": true },
    { "source": "/hizmetler/yol-cizgi.html", "destination": "/hizmetler/fircali-zemin.html", "permanent": true },
    { "source": "/hizmetler/dekoratif-zemin.html", "destination": "/hizmetler/zemin-bakim-onarim.html", "permanent": true }
  ]
}
